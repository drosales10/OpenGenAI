DATABASE_URL=postgresql://postgres:postgres@localhost:5432/genai
POSTGRES_DB=genai
POSTGRES_USER=postgres

# Clave Google AI Studio para Veo / Gemini (ruta directa, sin MuAPI)
# GOOGLE_API_KEY=your-key-from-aistudio.google.com/apikey
# Chat de agentes (AGENT_CHAT_BACKEND):
#   auto   = con internet + GOOGLE_API_KEY → Gemini 3.5; sin internet → Ollama (por defecto)
#   ollama = siempre local (llama3.2, etc.) aunque haya conexión
#   gemini = siempre Gemini (requiere internet y GOOGLE_API_KEY)
# AGENT_CHAT_BACKEND=auto
# GEMINI_CHAT_MODEL=gemini-3.5-flash

# Clave OpenAI para GPT Image / Sora 2 (ruta directa, sin MuAPI)
# OPENAI_API_KEY=sk-...

# Clave fal.ai para Flux / Kontext (ruta directa, sin MuAPI)
# También habilita Kling, Hailuo, Seedance, Wan, Runway y Suno (vía sonauto/MiniMax Music)
# FAL_KEY=your-key-from-fal.ai/dashboard/keys

# Clave Replicate para SDXL (alternativa a fal-ai/fast-sdxl)
# REPLICATE_API_TOKEN=r8_...

# Clave Ideogram para v3 generate / character / reframe (ruta directa, sin MuAPI)
# IDEOGRAM_API_KEY=your-key-from-developer.ideogram.ai

# Ollama — inferencia local open source (Z-Image Turbo, FLUX.2 Klein)
# Instala desde https://ollama.com y descarga: ollama pull x/flux2-klein:4b
# OLLAMA_HOST=http://127.0.0.1:11434
# Modelo para chat de agentes (opcional; si no se define, se elige automáticamente)
# OLLAMA_CHAT_MODEL=llama3.2:latest

# Wan2GP — video e imagen local (servidor Gradio)
# Instala https://github.com/deepbeepmeep/Wan2GP y define:
# WAN2GP_URL=http://127.0.0.1:7860

# Audio local — MusicGen / ACE-Step
# pip install audiocraft fastapi uvicorn torch && python scripts/local_audio_server.py
# LOCAL_AUDIO_HOST=http://127.0.0.1:8765

# ComfyUI — backend universal imagen / video / audio
# Instala https://github.com/comfyanonymous/ComfyUI y define:
# COMFYUI_URL=http://127.0.0.1:8188
# Checkpoints opcionales: COMFYUI_SDXL_CHECKPOINT, COMFYUI_FLUX_UNET, etc.


# Optional: override the default app database schema if you use a non-default setup.
POSTGRES_SCHEMA=public

# Optional: identity used for bootstrap of the internal admin API key.
INTERNAL_ADMIN_EMAIL=local-admin@open-generative.ai
INTERNAL_ADMIN_NAME=Local Admin